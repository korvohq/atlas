{
  "$id": "https://atlas.korvo.io/schemas/question.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Question",
  "description": "A research question — the starting point for investigation.",
  "type": "object",
  "required": ["id", "text", "status", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the question."
    },
    "text": {
      "type": "string",
      "minLength": 10,
      "description": "The research question itself."
    },
    "context": {
      "type": "string",
      "description": "Optional background or motivation for the question."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Topic tags for categorization and discovery."
    },
    "status": {
      "type": "string",
      "enum": ["open", "in_progress", "answered", "closed"],
      "description": "Current state of the question."
    },
    "createdBy": {
      "type": "string",
      "description": "Identifier of the person or agent who posed the question."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

